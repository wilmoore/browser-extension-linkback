{
  "name": "linkback",
  "version": "0.1.0",
  "description": "Bidirectional backlinks for the browser. Keyboard-first.",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build && npm run build:static",
    "build:static": "cp manifest.json sidebar.html inventory.html dist/ && cp -r icons dist/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:run": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "sync-version": "node -e \"const fs=require('fs');const p=JSON.parse(fs.readFileSync('package.json'));const m=JSON.parse(fs.readFileSync('manifest.json'));m.version=p.version;fs.writeFileSync('manifest.json',JSON.stringify(m,null,2)+'\\n')\"",
    "package": "npm run build && cd dist && zip -r ../dist.zip . && cd ..",
    "release": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major",
    "release:local": "make cws-deploy",
    "cws:init": "npx chrome-webstore-upload-cli init",
    "cws:upload": "make cws-upload",
    "cws:publish": "make cws-publish"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@playwright/test": "^1.48.0",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "chrome-webstore-upload-cli": "^3.3.1",
    "eslint": "^9.27.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "preact": "^10.26.4"
  }
}
